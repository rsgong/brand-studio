# Supabase — create a project at https://supabase.com/dashboard
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# n8n webhook base URL (where your generation workflows live)
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.app/webhook
VITE_N8N_PASSPHRASE=your-passphrase-here

# n8n webhook paths — must match the paths in the imported workflows
VITE_N8N_IMAGE_WEBHOOK_PATH=brand-studio-image
VITE_N8N_VIDEO_WEBHOOK_PATH=brand-studio-video

# ─────────────────────────────────────────────────────────────────────────────
# n8n Environment Variables (set these in n8n Settings → Variables)
# ─────────────────────────────────────────────────────────────────────────────
# BRAND_STUDIO_PASSPHRASE  — same value as VITE_N8N_PASSPHRASE above
# GOOGLE_AI_API_KEY        — for Veo 3.1 video generation
# CALLBACK_URL             — Edge Function URL, e.g.:
#                            https://YOUR_PROJECT_REF.supabase.co/functions/v1/video-generation-callback
