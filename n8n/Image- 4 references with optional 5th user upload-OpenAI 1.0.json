    {
      "parameters": {
        "jsCode": "// Collect all generated images and package as { images: [{mimeType, base64}] }\nconst images = [];\n\n$input.all().forEach(item => {\n  images.push({\n    mimeType: item.binary?.image?.mimeType || 'image/png',\n    base64: item.json.bin\n  });\n});\n\nreturn [{ json: { images } }];"
      },
