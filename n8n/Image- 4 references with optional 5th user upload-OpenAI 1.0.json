      "name": "Merge Reference Images",
      "executeOnce": true
    },
    {
      "parameters": {
        "jsCode": "// Flatten all 4 reference image items into a single item with all binary properties\nconst combined = { json: {}, binary: {} };\n\nfor (const item of $input.all()) {\n  if (Object.keys(combined.json).length === 0) {\n    combined.json = { ...item.json };\n  }\n  if (item.binary) {\n    for (const [key, val] of Object.entries(item.binary)) {\n      combined.binary[key] = val;\n    }\n  }\n}\n\nreturn [combined];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1296, 128],
      "id": "e760e2d4-1e59-4896-bbef-cc2bc3fcea85",
      "name": "Combine Reference Binaries"
    },
